# --- Database ---
# PostgreSQL in both dev and production (dev/prod parity).
# Local dev: start the bundled container with `docker compose up -d db`,
# which matches the credentials below. In production point this at your
# managed/self-hosted Postgres instance.
DATABASE_URL="postgresql://tradestats:tradestats@localhost:5432/tradestats?schema=public"

# --- Auth ---
# Secret used to sign session JWTs (HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me"

# --- Encryption ---
# 32-byte key (hex) for AES-256-GCM encryption of exchange API secrets. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-32-bytes-hex"

# --- Google sign-in (optional) ---
# OAuth Client ID (Web application) from https://console.cloud.google.com/apis/credentials
# Add your app origins to "Authorized JavaScript origins". No client secret needed.
# Leave unset to hide the "Continue with Google" button. Use the same value for both.
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# --- Scheduler ---
# Secret required to call the cron sync endpoint (/api/cron/sync).
CRON_SECRET="change-me"
# In-process scheduler ("true"/"false"). Keep "true" only for local dev with a
# long-running `next dev`. On serverless (Vercel) AND on the self-hosted server
# set "false" and trigger /api/cron/sync via an external cron — on the home
# server that's the host's system crontab (see docs/SELF_HOSTING.md, step 9.1).
ENABLE_SCHEDULER="true"

# --- Admin panel ---
# Comma-separated list of admin e-mails. These users get access to /admin.
ADMIN_EMAILS=""
# Collector service URL + Bearer token for its protected GET /metrics endpoint
# (admin "Order map" section). The token is one you generate yourself, e.g.
#   openssl rand -hex 32
# and it MUST match the collector's COLLECTOR_METRICS_TOKEN (passed to the
# collector service in docker-compose.prod.yml). If empty, the section falls back
# to Postgres aggregates only (no live feed status).
#
# Prod (docker-compose.prod.yml): app & collector share the compose network, so
#   COLLECTOR_URL=http://collector:8080   (this is already the compose default)
# Local: if you run the collector yourself, COLLECTOR_URL=http://localhost:8080
COLLECTOR_URL=""
COLLECTOR_METRICS_TOKEN=""
