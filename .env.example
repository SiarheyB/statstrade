# --- Database ---
# PostgreSQL in both dev and production (dev/prod parity).
# Local dev: start the bundled container with `docker compose up -d db`,
# which matches the credentials below. In production point this at your
# managed/self-hosted Postgres instance.
DATABASE_URL="postgresql://tradestats:tradestats@localhost:5432/tradestats?schema=public"

# --- Auth ---
# Secret used to sign session JWTs (HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me"

# --- Encryption ---
# 32-byte key (hex) for AES-256-GCM encryption of exchange API secrets. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-32-bytes-hex"

# --- Google sign-in (optional) ---
# OAuth Client ID (Web application) from https://console.cloud.google.com/apis/credentials
# Add your app origins to "Authorized JavaScript origins". No client secret needed.
# Leave unset to hide the "Continue with Google" button. Use the same value for both.
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# --- Cloudflare Turnstile (капча на регистрации, бесплатно, опционально) ---
# Создай виджет: https://dash.cloudflare.com → Turnstile → Add site.
# Site Key → NEXT_PUBLIC_TURNSTILE_SITE_KEY (публичный), Secret Key → TURNSTILE_SECRET.
# Пока не заданы — капча выключена, работают rate-limit + honeypot.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET=""

# --- Scheduler ---
# Secret required to call the cron sync endpoint (/api/cron/sync).
CRON_SECRET="change-me"
# In-process scheduler ("true"/"false"). Keep "true" only for local dev with a
# long-running `next dev`. On serverless (Vercel) AND on the self-hosted server
# set "false" and trigger /api/cron/sync via an external cron — on the home
# server that's the host's system crontab (see docs/SELF_HOSTING.md, step 9.1).
ENABLE_SCHEDULER="true"

# Enable detailed logs for the Forex/MT import endpoint (POST /api/accounts/[id]/import)
# Set to "true" to see start/stop and per‑step logs in Docker/server console.
ENABLE_IMPORT_LOGS="true"

# --- Admin panel ---
# Comma-separated list of admin e-mails. These users get access to /admin.
ADMIN_EMAILS=""
# Collector service URL + Bearer token for its protected GET /metrics endpoint
# (admin "Order map" section). The token is one you generate yourself, e.g.
#   openssl rand -hex 32
# and it MUST match the collector's COLLECTOR_METRICS_TOKEN (passed to the
# collector service in docker-compose.prod.yml). If empty, the section falls back
# to Postgres aggregates only (no live feed status).
#
# Prod (docker-compose.prod.yml): app & collector share the compose network, so
#   COLLECTOR_URL=http://collector:8080   (this is already the compose default)
# Local: if you run the collector yourself, COLLECTOR_URL=http://localhost:8080
COLLECTOR_URL=""
COLLECTOR_METRICS_TOKEN=""

# --- Collector (orderbook / orderflow) ---
# Эти переменные пробрасываются в docker-compose.yml и docker-compose.prod.yml
# в контейнер collector через ${OB_...:-default} подстановку.
#
# Какие пары собирать (через запятую).
# OB_SYMBOLS="BTCUSDT,ETHUSDT"
# OB_EXCHANGES="binance-futures,binance-spot"
#
# Как часто писать снапшот стакана (мс). Чем чаще — тем точнее график,
# но больше данных. 2000 = каждые 2 секунды.
# OB_SNAPSHOT_MS=2000
#
# Глубина стакана в % от mid-цены. 0.02 = 2% вверх и вниз.
# OB_DEPTH_PCT=0.02
#
# Минимальный нотионал для фильтра шума в $.
# OB_NOISE_MIN_NOTIONAL=50000
#
# Порог крупной сделки в $.
# OB_BIG_NOTIONAL=100000
#
# ═══════════════════════════════════════════════════════════════════════════════
# СРОК ХРАНЕНИЯ (RETENTION) — через сколько дней данные удаляются автоматически
# ═══════════════════════════════════════════════════════════════════════════════
# OB_RETENTION_DAYS — срок хранения СЫРЫХ СНАПШОТОВ СТАКАНА (таблица ObSnapshot).
#   Каждый снапшот — это все ценовые уровни стакана на момент записи. Это
#   самая тяжёлая таблица: миллионы строк. Хранить её долго = много места на
#   диске. Рекомендуется 7–14 дней — для heatmap и B/A графиков достаточно,
#   т.к. они читают rollup (предагрегированные минутные бакеты).
#   По умолчанию: 14 дней (в docker-compose) / 7 дней (в самом collector).
# OB_RETENTION_DAYS=14
#
# OB_TRADE_RETENTION_DAYS — срок хранения ИСТОРИИ СДЕЛОК, ФУТПРИНТА И КРУПНЫХ
#   ОРДЕРОВ (таблицы ObTrade, ObFootprint, ObBigTrade).
#   Дельта, футпринт и крупные сделки — это «история карты ордеров»: они
#   показывают, кто и как торговал. Данные легче снапшотов (одна строка = одна
#   сделка, а не все уровни стакана). Поэтому их можно хранить дольше — для
#   анализа трендов и поиска крупных игроков за недели/месяцы.
#   По умолчанию: 30 дней (в docker-compose и в самом collector).
#   Если хочешь хранить снапшоты 7 дней, а историю сделок 90 — поставь:
#     OB_RETENTION_DAYS=7
#     OB_TRADE_RETENTION_DAYS=90
#   Если OB_TRADE_RETENTION_DAYS не задан — используется OB_RETENTION_DAYS.
# OB_TRADE_RETENTION_DAYS=30
