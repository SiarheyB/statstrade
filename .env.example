# --- Database ---
# PostgreSQL in both dev and production (dev/prod parity).
# Local dev: start the bundled container with `docker compose up -d db`,
# which matches the credentials below. In production point this at your
# managed/self-hosted Postgres instance.
DATABASE_URL="postgresql://tradestats:tradestats@localhost:5432/tradestats?schema=public"

# --- Auth ---
# Secret used to sign session JWTs (HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me"

# --- Encryption ---
# 32-byte key (hex) for AES-256-GCM encryption of exchange API secrets. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-32-bytes-hex"

# --- Scheduler ---
# Secret required to call the cron sync endpoint (/api/cron/sync).
CRON_SECRET="change-me"
# In-process scheduler for local/self-hosted runs ("true"/"false").
# On serverless, set "false" and trigger /api/cron/sync via an external cron.
ENABLE_SCHEDULER="true"
