// Prisma schema for the trader-statistics app.
// PostgreSQL in both dev (local Docker) and production — dev/prod parity.
// Monetary values use Float (double precision): fine for crypto prices/PnL and
// keeps the JS analytics engine simple. Switch to Decimal if you ever need
// exact accounting-grade arithmetic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String            @id @default(cuid())
  email     String            @unique
  password  String? // bcrypt hash (null for Google-only accounts)
  googleId  String?           @unique // Google "sub" when linked to a Google account
  name      String?
  createdAt DateTime          @default(now())
  // Last time the user was seen on an authenticated request (throttled write,
  // ~once/hour). Drives adaptive auto-sync backoff: idle users sync less often.
  lastSeenAt DateTime?
  // JSON arrays of user-configurable dropdown options for trade annotations.
  entryPointOptions String?
  entryTypeOptions  String?
  mistakeOptions    String?
  patternOptions    String?
  // Two-factor auth (TOTP / Google Authenticator). Secret is AES-256-GCM
  // encrypted at rest; only active once the user confirms a code.
  twoFactorEnabled  Boolean @default(false)
  twoFactorSecret   String?
  accounts     ExchangeAccount[]
  annotations  TradeAnnotation[]
}

// Audit trail of admin-panel actions (delete user, force-sync, reset 2FA, etc.).
// Admins are defined by ADMIN_EMAILS (no role column), so the actor is stored by
// id + email snapshot. Append-only; surfaced in /admin/audit.
model AdminAudit {
  id          String   @id @default(cuid())
  actorId     String // admin user id
  actorEmail  String // snapshot of admin email at action time
  action      String // e.g. user.delete | account.sync | account.reset | user.reset2fa | content.refresh
  targetType  String? // user | account | content
  targetId    String? // affected entity id (when applicable)
  targetLabel String? // human-readable target (email / exchange label / feed)
  detail      String? // optional extra context
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

// Manual, user-supplied annotations attached to a reconstructed round-trip
// trade. Trades have no DB row of their own, so they are referenced by a
// stable composite key (account + symbol + market + entry timestamp).
model TradeAnnotation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeKey   String
  entryPoint String? // ТВХ (точка входа)
  entryType  String? // тип входа
  mistake    String? // ошибка в сделке
  pattern    String? // паттерн
  stopLoss   Float? // цена стоп-лосса (для маркера на графике)
  note       String?
  updatedAt  DateTime @updatedAt

  @@unique([userId, tradeKey])
  @@index([userId])
}

// A connected exchange account (one API key) belonging to a user.
model ExchangeAccount {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange   String // binance | bybit | okx | mt4 | mt5 | manual
  label      String
  // Data source. "exchange" = CCXT API sync; mt4/mt5/manual = file-imported
  // round-trips (no API keys, no sync).
  source          String  @default("exchange")
  accountCurrency String  @default("USD") // account currency for imported (forex) trades
  assetClass      String? // null = crypto | "forex"
  apiKey     String? // AES-256-GCM encrypted (null for imported/manual accounts)
  apiSecret  String? // AES-256-GCM encrypted (null for imported/manual accounts)
  passphrase String? // AES-256-GCM encrypted (OKX requires a passphrase)
  marketType String    @default("both") // spot | futures | both
  demoTrading Boolean  @default(false) // Bybit Demo Trading key -> use demo API host
  balance    Float?    // last fetched account balance/equity in USDT (deposit)
  balanceAt  DateTime? // when balance was last fetched
  capital    Float?    // user-set capital for this account (Overview), overrides balance
  createdAt  DateTime  @default(now())
  lastSyncAt DateTime?
  syncStatus String    @default("idle") // idle | syncing | error
  syncError  String?
  // Background auto-sync on a schedule.
  autoSync            Boolean @default(false)
  syncIntervalMinutes Int     @default(60)
  // Chunked background import progress. A scan walks a persisted task plan
  // (one task per trading pair on per-symbol exchanges like Binance) in
  // time-bounded chunks so it survives serverless timeouts.
  syncPhase    String? // null | "full" | "incremental"
  syncPlan     String? // JSON array of "kind|symbol" tasks for the active scan
  syncCursor   Int       @default(0) // index of the next task to process
  syncTotal    Int       @default(0) // total tasks in the active scan
  syncImported Int       @default(0) // fills imported so far in the active scan
  fullSyncAt   DateTime? // when the last full (all-pairs) scan completed
  fills          Fill[]
  importedTrades ImportedTrade[]

  @@index([userId])
}

// A closed round-trip imported from a MetaTrader 4/5 report (or entered
// manually). Unlike crypto trades these are NOT reconstructed — the money
// (profit / swap / commission) is taken as-is from the broker, in account
// currency. The stats layer merges these with reconstructed crypto trades.
model ImportedTrade {
  id           String          @id @default(cuid())
  accountId    String
  account      ExchangeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  source       String // mt4 | mt5 | manual
  externalId   String // ticket (MT4) / position id (MT5) — for dedup
  symbol       String // EURUSD, XAUUSD, US30 ...
  base         String
  quote        String
  market       String  @default("forex")
  side         String // long | short
  lots         Float
  qty          Float // lots * contractSize (base units)
  contractSize Float   @default(100000)
  entryTime    DateTime
  exitTime     DateTime
  entryPrice   Float
  exitPrice    Float
  stopLoss     Float?
  takeProfit   Float?
  commission   Float    @default(0) // account currency
  swap         Float    @default(0) // account currency
  grossProfit  Float // broker profit before swap/commission, account currency
  netPnl       Float // grossProfit + swap - commission
  pips         Float?
  currency     String   @default("USD") // account currency at import time
  comment      String?
  importedAt   DateTime @default(now())
  importBatch  String? // id of the upload batch (for rollback)

  @@unique([accountId, externalId])
  @@index([accountId])
  @@index([accountId, exitTime])
}

// A single execution (fill) imported from an exchange. Round-trip trades are
// reconstructed from these on the fly by the analytics layer.
model Fill {
  id           String          @id @default(cuid())
  accountId    String
  account      ExchangeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  exchange     String
  tradeId      String // exchange-side fill/trade id
  orderId      String?
  symbol       String // e.g. BTC/USDT
  base         String // BTC
  quote        String // USDT
  market       String // spot | swap | future
  side         String // buy | sell
  price        Float
  amount       Float // base amount filled
  cost         Float // quote cost = price * amount
  fee          Float          @default(0) // fee amount
  feeCurrency  String?
  realizedPnl  Float? // exchange-provided realized pnl, when available (futures)
  takerOrMaker String?
  timestamp    DateTime
  createdAt    DateTime        @default(now())

  @@unique([accountId, tradeId, symbol])
  @@index([accountId])
  @@index([accountId, timestamp])
  @@index([accountId, symbol])
}

// Aggregated taker-trade volume per snapshot interval — written by the collector
// from the aggTrades stream. Drives the delta / cumulative-delta panel under the
// orderbook heatmap. buyVol/sellVol are aggressor base volumes.
model ObTrade {
  id       BigInt   @id @default(autoincrement())
  symbol   String
  exchange String
  t        DateTime @db.Timestamptz(3)
  buyVol   Float    @default(0)
  sellVol  Float    @default(0)

  @@index([symbol, exchange, t])
  @@index([symbol, t]) // выборка по всем биржам (exchange="all")
}

// Traded volume per price bin per snapshot — written by the collector from the
// trade stream. Drives the footprint/cluster overlay (buy vs sell volume at each
// price level inside a candle).
model ObFootprint {
  id       BigInt   @id @default(autoincrement())
  symbol   String
  exchange String
  t        DateTime @db.Timestamptz(3)
  price    Float
  buyVol   Float    @default(0)
  sellVol  Float    @default(0)

  @@index([symbol, exchange, t])
  @@index([symbol, t]) // выборка по всем биржам (exchange="all")
}

// Large market trades (taker prints above a notional threshold) — written by the
// collector from the trade stream. Drives the "large orders" feed.
model ObBigTrade {
  id       BigInt   @id @default(autoincrement())
  symbol   String
  exchange String
  t        DateTime @db.Timestamptz(3)
  price    Float
  qty      Float
  side     String // buy | sell

  @@index([symbol, exchange, t])
}

// Aggregated crypto news from external RSS sources. Global (not per-user);
// Orderbook heatmap snapshots — written by the standalone collector service
// (collector/), one row per non-empty price bin per snapshot. Global market
// data (not per-user). Read by /api/orderflow to render the limit-order heatmap.
// High-volume table: keep it lean and prune by retention (see collector).
model ObSnapshot {
  id       BigInt   @id @default(autoincrement())
  symbol   String // BTCUSDT
  exchange String // binance-futures
  t        DateTime @db.Timestamptz(3) // snapshot timestamp (absolute instant, UTC)
  price    Float // price-bin center
  bidVol   Float    @default(0) // aggregated bid size in the bin (base units)
  askVol   Float    @default(0) // aggregated ask size in the bin (base units)

  @@index([symbol, exchange, t])
  @@index([symbol, t]) // выборка по всем биржам (exchange="all")
}

// Предагрегация снапшотов стакана в минутные бакеты × ценовой уровень. Пишется
// коллектором (накапливает снапшоты за минуту в памяти и сбрасывает завершённый
// бакет одним upsert). Источник для heatmap-сетки и панели B/A: вместо скана
// ~40М сырых строк ObSnapshot на каждый запрос читаем ~в 30 раз меньше строк.
// volSum/bidSum/askSum — суммы по всем снапшотам бакета на этом уровне; делитель
// (число снапшотов в бакете) хранится в ObRollupBucket. Прунится по ретеншну.
model ObSnapshotRollup {
  symbol   String
  exchange String
  bucket   DateTime @db.Timestamptz(3) // начало минутного бакета (UTC)
  price    Float // ценовой бин
  volSum   Float    @default(0) // Σ(bidVol+askVol) по снапшотам бакета
  bidSum   Float    @default(0) // Σ bidVol
  askSum   Float    @default(0) // Σ askVol

  @@id([symbol, exchange, bucket, price])
  @@index([symbol, exchange, bucket])
  @@index([symbol, bucket]) // выборка по всем биржам (exchange="all")
}

// Метаданные минутного бакета: сколько снапшотов в него попало (делитель для
// усреднения «высоты стен») и Σ mid (для B/A-зоны ±1%). Маленькая таблица —
// один ряд на (symbol,exchange,минута).
model ObRollupBucket {
  symbol   String
  exchange String
  bucket   DateTime @db.Timestamptz(3)
  snaps    Int      @default(0) // число снапшотов фида в бакете
  midSum   Float    @default(0) // Σ mid по снапшотам (avg mid = midSum/snaps)

  @@id([symbol, exchange, bucket])
  @@index([symbol, bucket]) // выборка по всем биржам (exchange="all")
}

// Editable collector settings (read by the collector every ~30s, edited in the
// admin panel — no redeploy). One row per symbol: minCoins = keep only limit
// levels whose resting size (bid+ask) is at least this many base coins. Bigger
// threshold = only large walls stored = far less data / disk.
model CollectorConfig {
  symbol    String   @id // "BTCUSDT", "ETHUSDT", …
  minCoins  Float // minimum resting size (base coins) to record a level
  updatedAt DateTime @updatedAt
}

// Вкл/выкл биржи для синхронизации аккаунтов (тумблер в админ-панели). Нет
// строки → биржа считается включённой (дефолт). Влияет только на то, какие
// биржи пользователь может подключить; карты ордеров/ликвидаций не затрагивает.
model ExchangeToggle {
  exchange    String   @id // ccxt id: binance | bybit | okx | kraken | ...
  enabled     Boolean  @default(true)
  // Разрешён ли демо/testnet-счёт для этой биржи. NULL = взять статичный дефолт
  // (SUPPORTED_EXCHANGES[id].supportsDemo). Админ может переопределить.
  demoEnabled Boolean?
  updatedAt   DateTime @updatedAt
}

// deduped by canonical URL and refreshed lazily by the /api/news endpoint.
model NewsItem {
  id          String   @id @default(cuid())
  source      String // coindesk | cointelegraph | decrypt | forklog | beincrypto-ru | incrypted
  lang        String   @default("en") // en | ru — language of the article/headline
  title       String
  url         String   @unique
  summary     String?
  imageUrl    String?
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([lang, publishedAt])
  @@index([source])
}

// Risk-manager limits. One row per user is the default profile (accountId = "");
// additional rows with a real accountId override the default for that account.
model RiskProfile {
  id             String   @id @default(cuid())
  userId         String
  accountId      String   @default("") // "" = default profile, else per-account override
  enabled        Boolean  @default(false)
  maxStopsPerDay Int? // max losing trades per day before "stop"
  // JSON: { day|week|month|year: { on: bool, value: number, unit: "pct"|"amount" } }
  lossLimits     String?
  // JSON: { on: bool, value: number, unit: "pct"|"amount" } — risk per trade (1R),
  // used to compute the risk-reward (R-multiple) column on trades.
  riskPerTrade   String?
  updatedAt      DateTime @updatedAt

  @@unique([userId, accountId])
  @@index([userId])
}

// Economic-calendar event ingested from the free ForexFactory/faireconomy JSON
// feed. Global (not per-user); deduped by time+currency+title and refreshed
// lazily by the /api/econcal endpoint.
model EconomicEvent {
  id        String   @id @default(cuid())
  time      DateTime // event time (UTC)
  currency  String // USD, EUR, GBP ...
  country   String // United States, Euro Area ... (derived)
  title     String
  impact    String // high | medium | low | holiday
  category  String? // Employment | Inflation | Interest Rate ... (derived)
  forecast  String?
  previous  String?
  actual    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([time, currency, title])
  @@index([time])
}
