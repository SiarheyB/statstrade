// Prisma schema for the trader-statistics app.
// PostgreSQL in both dev (local Docker) and production — dev/prod parity.
// Monetary values use Float (double precision): fine for crypto prices/PnL and
// keeps the JS analytics engine simple. Switch to Decimal if you ever need
// exact accounting-grade arithmetic.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String            @id @default(cuid())
  email     String            @unique
  password  String? // bcrypt hash (null for Google-only accounts)
  googleId  String?           @unique // Google "sub" when linked to a Google account
  name      String?
  createdAt DateTime          @default(now())
  // JSON arrays of user-configurable dropdown options for trade annotations.
  entryPointOptions String?
  entryTypeOptions  String?
  mistakeOptions    String?
  patternOptions    String?
  // Two-factor auth (TOTP / Google Authenticator). Secret is AES-256-GCM
  // encrypted at rest; only active once the user confirms a code.
  twoFactorEnabled  Boolean @default(false)
  twoFactorSecret   String?
  accounts     ExchangeAccount[]
  annotations  TradeAnnotation[]
}

// Manual, user-supplied annotations attached to a reconstructed round-trip
// trade. Trades have no DB row of their own, so they are referenced by a
// stable composite key (account + symbol + market + entry timestamp).
model TradeAnnotation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tradeKey   String
  entryPoint String? // ТВХ (точка входа)
  entryType  String? // тип входа
  mistake    String? // ошибка в сделке
  pattern    String? // паттерн
  stopLoss   Float? // цена стоп-лосса (для маркера на графике)
  note       String?
  updatedAt  DateTime @updatedAt

  @@unique([userId, tradeKey])
  @@index([userId])
}

// A connected exchange account (one API key) belonging to a user.
model ExchangeAccount {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange   String // binance | bybit | okx | mt4 | mt5 | manual
  label      String
  // Data source. "exchange" = CCXT API sync; mt4/mt5/manual = file-imported
  // round-trips (no API keys, no sync).
  source          String  @default("exchange")
  accountCurrency String  @default("USD") // account currency for imported (forex) trades
  assetClass      String? // null = crypto | "forex"
  apiKey     String? // AES-256-GCM encrypted (null for imported/manual accounts)
  apiSecret  String? // AES-256-GCM encrypted (null for imported/manual accounts)
  passphrase String? // AES-256-GCM encrypted (OKX requires a passphrase)
  marketType String    @default("both") // spot | futures | both
  demoTrading Boolean  @default(false) // Bybit Demo Trading key -> use demo API host
  balance    Float?    // last fetched account balance/equity in USDT (deposit)
  balanceAt  DateTime? // when balance was last fetched
  createdAt  DateTime  @default(now())
  lastSyncAt DateTime?
  syncStatus String    @default("idle") // idle | syncing | error
  syncError  String?
  // Background auto-sync on a schedule.
  autoSync            Boolean @default(false)
  syncIntervalMinutes Int     @default(60)
  // Chunked background import progress. A scan walks a persisted task plan
  // (one task per trading pair on per-symbol exchanges like Binance) in
  // time-bounded chunks so it survives serverless timeouts.
  syncPhase    String? // null | "full" | "incremental"
  syncPlan     String? // JSON array of "kind|symbol" tasks for the active scan
  syncCursor   Int       @default(0) // index of the next task to process
  syncTotal    Int       @default(0) // total tasks in the active scan
  syncImported Int       @default(0) // fills imported so far in the active scan
  fullSyncAt   DateTime? // when the last full (all-pairs) scan completed
  fills          Fill[]
  importedTrades ImportedTrade[]

  @@index([userId])
}

// A closed round-trip imported from a MetaTrader 4/5 report (or entered
// manually). Unlike crypto trades these are NOT reconstructed — the money
// (profit / swap / commission) is taken as-is from the broker, in account
// currency. The stats layer merges these with reconstructed crypto trades.
model ImportedTrade {
  id           String          @id @default(cuid())
  accountId    String
  account      ExchangeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  source       String // mt4 | mt5 | manual
  externalId   String // ticket (MT4) / position id (MT5) — for dedup
  symbol       String // EURUSD, XAUUSD, US30 ...
  base         String
  quote        String
  market       String  @default("forex")
  side         String // long | short
  lots         Float
  qty          Float // lots * contractSize (base units)
  contractSize Float   @default(100000)
  entryTime    DateTime
  exitTime     DateTime
  entryPrice   Float
  exitPrice    Float
  stopLoss     Float?
  takeProfit   Float?
  commission   Float    @default(0) // account currency
  swap         Float    @default(0) // account currency
  grossProfit  Float // broker profit before swap/commission, account currency
  netPnl       Float // grossProfit + swap - commission
  pips         Float?
  currency     String   @default("USD") // account currency at import time
  comment      String?
  importedAt   DateTime @default(now())
  importBatch  String? // id of the upload batch (for rollback)

  @@unique([accountId, externalId])
  @@index([accountId])
  @@index([accountId, exitTime])
}

// A single execution (fill) imported from an exchange. Round-trip trades are
// reconstructed from these on the fly by the analytics layer.
model Fill {
  id           String          @id @default(cuid())
  accountId    String
  account      ExchangeAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  exchange     String
  tradeId      String // exchange-side fill/trade id
  orderId      String?
  symbol       String // e.g. BTC/USDT
  base         String // BTC
  quote        String // USDT
  market       String // spot | swap | future
  side         String // buy | sell
  price        Float
  amount       Float // base amount filled
  cost         Float // quote cost = price * amount
  fee          Float          @default(0) // fee amount
  feeCurrency  String?
  realizedPnl  Float? // exchange-provided realized pnl, when available (futures)
  takerOrMaker String?
  timestamp    DateTime
  createdAt    DateTime        @default(now())

  @@unique([accountId, tradeId, symbol])
  @@index([accountId])
  @@index([accountId, timestamp])
  @@index([accountId, symbol])
}

// Aggregated crypto news from external RSS sources. Global (not per-user);
// deduped by canonical URL and refreshed lazily by the /api/news endpoint.
model NewsItem {
  id          String   @id @default(cuid())
  source      String // coindesk | cointelegraph | decrypt | forklog | beincrypto-ru | incrypted
  lang        String   @default("en") // en | ru — language of the article/headline
  title       String
  url         String   @unique
  summary     String?
  imageUrl    String?
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([lang, publishedAt])
  @@index([source])
}

// Risk-manager limits. One row per user is the default profile (accountId = "");
// additional rows with a real accountId override the default for that account.
model RiskProfile {
  id             String   @id @default(cuid())
  userId         String
  accountId      String   @default("") // "" = default profile, else per-account override
  enabled        Boolean  @default(false)
  maxStopsPerDay Int? // max losing trades per day before "stop"
  // JSON: { day|week|month|year: { on: bool, value: number, unit: "pct"|"amount" } }
  lossLimits     String?
  // JSON: { on: bool, value: number, unit: "pct"|"amount" } — risk per trade (1R),
  // used to compute the risk-reward (R-multiple) column on trades.
  riskPerTrade   String?
  updatedAt      DateTime @updatedAt

  @@unique([userId, accountId])
  @@index([userId])
}

// Economic-calendar event ingested from the free ForexFactory/faireconomy JSON
// feed. Global (not per-user); deduped by time+currency+title and refreshed
// lazily by the /api/econcal endpoint.
model EconomicEvent {
  id        String   @id @default(cuid())
  time      DateTime // event time (UTC)
  currency  String // USD, EUR, GBP ...
  country   String // United States, Euro Area ... (derived)
  title     String
  impact    String // high | medium | low | holiday
  category  String? // Employment | Inflation | Interest Rate ... (derived)
  forecast  String?
  previous  String?
  actual    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([time, currency, title])
  @@index([time])
}
