# Postgres connection (Neon сейчас, позже домашний сервер — меняется только это).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Что собираем
SYMBOL=BTCUSDT
EXCHANGE=binance-futures

# Параметры агрегации
BIN_SIZE=25            # ширина ценового бина, $
SNAPSHOT_MS=2000       # как часто писать снапшот, мс
DEPTH_PCT=0.02         # глубина вокруг mid (±2%)
NOISE_MIN_NOTIONAL=50000  # фильтр шума: минимальный нотионал бина, $
RETENTION_DAYS=7       # общий дефолт ретеншна (фолбэк для двух ниже)
RAW_RETENTION_DAYS=2   # сырые ObSnapshot/ObTrade/... — нужны лишь живому профилю
ROLLUP_RETENTION_DAYS=14  # компактная история heatmap/B-A в rollup — дольше

# Bearer-токен для защищённого эндпоинта GET /metrics (его опрашивает
# админ-панель Next.js, раздел «Карта ордеров»). Должен совпадать с
# COLLECTOR_METRICS_TOKEN в Next.js. Если пусто — /metrics отдаёт 404 (закрыт).
COLLECTOR_METRICS_TOKEN=
