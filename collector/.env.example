# Postgres connection (Neon сейчас, позже домашний сервер — меняется только это).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Что собираем
SYMBOL=BTCUSDT
EXCHANGE=binance-futures

# Параметры агрегации
BIN_SIZE=25            # ширина ценового бина, $
SNAPSHOT_MS=2000       # как часто писать снапшот, мс
DEPTH_PCT=0.02         # глубина вокруг mid (±2%)
NOISE_MIN_NOTIONAL=50000  # фильтр шума: минимальный нотионал бина, $

# ═══════════════════════════════════════════════════════════════════════════════
# СРОК ХРАНЕНИЯ (RETENTION) — через сколько дней данные удаляются автоматически
# ═══════════════════════════════════════════════════════════════════════════════
# RETENTION_DAYS — срок хранения СЫРЫХ СНАПШОТОВ СТАКАНА (таблица ObSnapshot).
#   Каждый снапшот — это все ценовые уровни стакана на момент записи. Это
#   самая тяжёлая таблица: миллионы строк. Хранить её долго = много места на
#   диске. Рекомендуется 7–14 дней — для heatmap и B/A графиков достаточно,
#   т.к. они читают rollup (предагрегированные минутные бакеты).
#   По умолчанию: 7 дней.
RETENTION_DAYS=7

# TRADE_RETENTION_DAYS — срок хранения ИСТОРИИ СДЕЛОК, ФУТПРИНТА И КРУПНЫХ
#   ОРДЕРОВ (таблицы ObTrade, ObFootprint, ObBigTrade).
#   Дельта (delta), футпринт (footprint) и крупные сделки (big trades) —
#   это «история карты ордеров»: они показывают, кто и как торговал. Данные
#   легче снапшотов (одна строка = одна сделка, а не все уровни стакана).
#   Поэтому их можно хранить дольше — для анализа трендов и поиска крупных
#   игроков за недели/месяцы.
#   По умолчанию: 30 дней (или значение RETENTION_DAYS, если не задан).
#   Если хочешь хранить снапшоты 7 дней, а историю сделок 90 — поставь:
#     RETENTION_DAYS=7
#     TRADE_RETENTION_DAYS=90
#   Если TRADE_RETENTION_DAYS не задан — используется значение RETENTION_DAYS.
TRADE_RETENTION_DAYS=30

# CANDLE_RETENTION_DAYS — срок хранения СВЕЧЕЙ OHLCV (таблица ObCandle).
#   Свечи — это open/high/low/close/volume для каждого таймфрейма (5m–1w).
#   Данные очень лёгкие: 24 строки в день на символ на таймфрейм.
#   Можно хранить долго — для глубокой истории на карте ордеров.
#   По умолчанию: 365 дней.
CANDLE_RETENTION_DAYS=365

# Bearer-токен для защищённого эндпоинта GET /metrics (его опрашивает
# админ-панель Next.js, раздел «Карта ордеров»). Должен совпадать с
# COLLECTOR_METRICS_TOKEN в Next.js. Если пусто — /metrics отдаёт 404 (закрыт).
COLLECTOR_METRICS_TOKEN=
